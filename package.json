{
  "name": "@clevertask/react-sortable-tree",
  "version": "0.0.12",
  "type": "module",
  "license": "MIT",
  "author": "CleverTask",
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/clevertask/react-sortable-tree#readme",
  "bugs": {
    "url": "https://github.com/clevertask/react-sortable-tree/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clevertask/react-sortable-tree"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/react-sortable-tree.js"
    },
    "./e2e": {
      "types": "./dist/e2e/utils/index.d.ts",
      "default": "./dist/e2e/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:dev": "playwright test --ui",
    "build": "rm -rf dist && vite build && vite build -c vite.test.config.ts && tsc -p tsconfig.types.json --noCheck",
    "lint": "eslint .",
    "format": "oxfmt",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@griffel/react": "^1.6.1",
    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  },
  "peerDependencies": {
    "react": ">=18.3.1 <20.0.0",
    "react-dom": ">=18.3.1 <20.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,css}": "oxfmt --no-error-on-unmatched-pattern"
  }
}
